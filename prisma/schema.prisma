// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  REQUESTER
  ADMIN
}

enum ProofRequestStatus {
  OPEN
  SOLVED
  SUSPICIOUS
  UNRESOLVED
  CLOSED
}

enum ProofRequestVisibility {
  PRIVATE_LINK
}

enum ProofReplyVerdict {
  CONFIRMED
  SUSPICIOUS
  UNSURE
}

enum EvidenceOwnerKind {
  REQUEST
  REPLY
}

enum ProofForwardStatus {
  SENT
  FAILED
}

enum PaymentKind {
  DONATION
  URGENT_BOOST
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  role            UserRole       @default(REQUESTER)
  isAdultVerified Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  proofRequests   ProofRequest[]
  authSessions    AuthSession[]
  forwards        ProofRequestForward[]
  payments        Payment[]
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique @db.VarChar(64)
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model AuthMagicLink {
  id        String   @id @default(cuid())
  email     String   @db.VarChar(320)
  tokenHash String   @unique @db.VarChar(64)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, createdAt])
}

model ProofRequest {
  id              String                 @id @default(cuid())
  creatorId       String
  title           String                 @db.VarChar(120)
  body            String                 @db.Text
  category        String                 @db.VarChar(64)
  locationHint    String?                @db.VarChar(160)
  listingUrl      String?                @db.VarChar(2048)
  status          ProofRequestStatus     @default(OPEN)
  visibility      ProofRequestVisibility @default(PRIVATE_LINK)
  urgentBoostPaidAt DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  creator         User                   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  replies         ProofReply[]
  evidence        RequestEvidence[]
  forwards        ProofRequestForward[]
  payments        Payment[]

  @@index([creatorId, createdAt])
}

model ProofRequestForward {
  id             String             @id @default(cuid())
  requestId      String
  senderId       String
  recipientEmail String             @db.VarChar(320)
  note           String?            @db.VarChar(500)
  helperLinkUrl  String             @db.VarChar(2048)
  status         ProofForwardStatus @default(SENT)
  createdAt      DateTime           @default(now())
  proofRequest   ProofRequest       @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sender         User               @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([requestId, createdAt])
  @@index([senderId, createdAt])
}

model ProofReply {
  id            String            @id @default(cuid())
  requestId     String
  helperName    String?           @db.VarChar(80)
  body          String            @db.Text
  verdict       ProofReplyVerdict @default(UNSURE)
  createdAt     DateTime          @default(now())
  proofRequest  ProofRequest      @relation(fields: [requestId], references: [id], onDelete: Cascade)
  evidence      RequestEvidence[]

  @@index([requestId, createdAt])
}

model RequestEvidence {
  id           String            @id @default(cuid())
  requestId    String
  replyId      String?
  ownerKind    EvidenceOwnerKind
  storageKey   String            @unique @db.VarChar(255)
  mimeType     String            @db.VarChar(64)
  originalName String            @db.VarChar(160)
  sizeBytes    Int
  createdAt    DateTime          @default(now())
  proofRequest ProofRequest      @relation(fields: [requestId], references: [id], onDelete: Cascade)
  proofReply   ProofReply?       @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@index([requestId, createdAt])
  @@index([replyId, createdAt])
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  requestId       String?
  kind            PaymentKind
  status          PaymentStatus @default(PENDING)
  stripeSessionId String        @unique @db.VarChar(255)
  amountCents     Int?
  currency        String?       @db.VarChar(8)
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  request         ProofRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  @@index([kind, createdAt])
  @@index([userId, createdAt])
}
