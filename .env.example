DATABASE_URL="postgresql://proofping:proofping@localhost:5432/proofping?schema=public"
APP_URL="http://localhost:3000"

# Phone / LAN testing — your machine's Wi‑Fi IP for allowedDevOrigins (comma-separated ok)
# DEV_LAN_ORIGIN="192.168.0.104"

# Auth
ENABLE_DEMO_AUTH="false"
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_LINK_DELIVERY="email"

# Admin (comma-separated emails also supported via ADMIN_EMAILS)
ADMIN_EMAIL="you@example.com"

# Resend magic-link sign-in
RESEND_API_KEY="re_..."
EMAIL_FROM="ProofPing <onboarding@resend.dev>"

# Stripe (optional)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PRICE_DONATION="price_..."
STRIPE_PRICE_URGENT_BOOST="price_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# OpenAI — optional “Improve wording” helper
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"
